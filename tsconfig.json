{
  "extends": "./.wxt/tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "types": ["chrome", "node"],
    "lib": ["dom", "dom.iterable", "esnext"],
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": true,
    "jsx": "react-jsx",
    "allowJs": false,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "strict": true,
    "paths": {
      "@": ["./src"],
      "@/*": ["./src/*"],
      "~": ["./src"],
      "~/*": ["./src/*"],
      "@@": ["."],
      "@@/*": ["./*"],
      "~~": ["."],
      "~~/*": ["./*"],
      "@saysike/ui": ["./src/lib/ui/src"],
      "@saysike/ui/*": ["./src/lib/ui/src/*"],
      "@saysike/utils": ["./src/lib/utils/src"],
      "@saysike/utils/*": ["./src/lib/utils/src/*"],
      "@saysike/http": ["./src/lib/http/src"],
      "@saysike/http/*": ["./src/lib/http/src/*"],
      "@saysike/schemas": ["./src/lib/schemas/src"],
      "@saysike/schemas/*": ["./src/lib/schemas/src/*"]
    }
  }
}
