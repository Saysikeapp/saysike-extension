{
  "name": "saysike-extension",
  "version": "0.0.2",
  "private": true,
  "description": "Saysike Browser Extension",
  "type": "module",
  "scripts": {
    "dev": "wxt --mv3",
    "dev:firefox": "wxt --mv3 -b firefox",
    "build": "wxt --mv3 build",
    "build:firefox": "wxt --mv3 build -b firefox",
    "zip": "wxt --mv3 zip",
    "zip:firefox": "wxt --mv3 zip -b firefox",
    "postinstall": "wxt prepare",
    "check-types": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "keywords": [],
  "author": "Joseph L Hawkins",
  "dependencies": {
    "@saysike/http": "workspace:*",
    "@saysike/schemas": "workspace:*",
    "@saysike/ui": "workspace:*",
    "@saysike/utils": "workspace:*",
    "@tanstack/react-query": "^5.90.9",
    "better-auth": "^1.4.18",
    "dayjs": "^1.11.12",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-error-boundary": "^6.0.0",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/compat": "^1.2.9",
    "@next/eslint-plugin-next": "^15.3.3",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/eslint-plugin-query": "^5.91.2",
    "@types/bun": "^1.3.8",
    "@types/chrome": "^0.1.31",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.34.0",
    "@tanstack/react-query-devtools": "^5.91.1",
    "@wxt-dev/module-react": "^1.1.5",
    "bun": "1.3.8",
    "dotenv": "^17.2.3",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-only-warn": "^1.1.0",
    "eslint-plugin-prettier": "^5.4.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-storybook": "^10.2.1",
    "eslint-plugin-testing-library": "^7.5.1",
    "eslint-plugin-turbo": "^2.8.3",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "postcss": "^8.5.4",
    "prettier": "^3.5.3",
    "ts-jest": "^29.3.4",
    "tailwindcss": "^4.1.18",
    "tsconfig-paths": "^4.2.0",
    "turbo": "^2.8.3",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.59.0",
    "wxt": "^0.20.13"
  },
  "engines": {
    "node": ">=22",
    "npm": ">=10",
    "bun": "1.3.8"
  },
  "packageManager": "bun@1.3.8",
  "workspaces": [
    "apps/*",
    "packages/*",
    "infrastructure/*",
    "services/*"
  ]
}
