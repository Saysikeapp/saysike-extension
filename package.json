{
  "name": "saysike-extension",
  "version": "0.0.6",
  "private": true,
  "description": "Saysike Browser Extension",
  "type": "module",
  "scripts": {
    "dev": "wxt --mv3",
    "dev:firefox": "wxt --mv3 -b firefox",
    "build": "wxt --mv3 build",
    "build:firefox": "wxt --mv3 build -b firefox",
    "zip": "wxt --mv3 zip",
    "zip:firefox": "wxt --mv3 zip -b firefox",
    "postinstall": "wxt prepare",
    "check-types": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "storybook": "storybook dev -p 6006 -c src/lib/ui/.storybook",
    "storybook:build": "storybook build -c src/lib/ui/.storybook",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "Joseph L Hawkins",
  "dependencies": {
    "@hookform/error-message": "^2.0.1",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.90.9",
    "better-auth": "^1.4.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.12",
    "focus-trap": "^7.5.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-error-boundary": "^6.0.0",
    "react-hook-form": "^7.68.0",
    "react-svg": "^16.1.34",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/compat": "^1.2.9",
    "@storybook/addon-docs": "^10.2.1",
    "@storybook/addon-links": "^10.2.1",
    "@storybook/addon-themes": "^10.2.1",
    "@storybook/react-vite": "^10.2.1",
    "@storybook/testing-library": "^0.2.2",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/eslint-plugin-query": "^5.91.2",
    "@tanstack/react-query-devtools": "^5.91.1",
    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "^16",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.34.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "@wxt-dev/module-react": "^1.1.5",
    "dotenv": "^17.2.3",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.4.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-storybook": "^10.2.1",
    "eslint-plugin-testing-library": "^7.5.1",
    "husky": "^9.1.7",
    "msw": "^2.13.6",
    "prettier": "^3.5.3",
    "storybook": "^10.2.1",
    "tailwindcss": "^4.1.18",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite-tsconfig-paths": "^4.3.2",
    "vitest": "^4.1.5",
    "wxt": "^0.20.13"
  },
  "engines": {
    "node": ">=22",
    "bun": "1.3.8"
  },
  "packageManager": "bun@1.3.8"
}
